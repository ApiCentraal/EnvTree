{
  "name": "envtree-extension",
  "displayName": "EnvTree",
  "description": "Developer-first secret management for your projects",
  "repository": {
    "type": "git",
    "url": "https://github.com/apicentraal/envtree.git"
  },
  "version": "1.0.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Snippets"
  ],
  "activationEvents": [
    "workspaceContains:**/.git"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "envtree.init",
        "title": "EnvTree: Initialize Project",
        "icon": "$(add)",
        "category": "EnvTree"
      },
      {
        "command": "envtree.addSecret",
        "title": "EnvTree: Add Secret",
        "icon": "$(key)",
        "category": "EnvTree"
      },
      {
        "command": "envtree.inject",
        "title": "EnvTree: Inject to .env",
        "icon": "$(file-add)",
        "category": "EnvTree"
      },
      {
        "command": "envtree.rotate",
        "title": "EnvTree: Rotate Secret",
        "icon": "$(refresh)",
        "category": "EnvTree"
      },
      {
        "command": "envtree.refresh",
        "title": "EnvTree: Refresh",
        "icon": "$(refresh)",
        "category": "EnvTree"
      },
      {
        "command": "envtree.deleteSecret",
        "title": "EnvTree: Delete Secret",
        "icon": "$(trash)",
        "category": "EnvTree"
      },
      {
        "command": "envtree.settings",
        "title": "EnvTree: Settings",
        "icon": "$(gear)",
        "category": "EnvTree"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "envtreeExplorer",
          "name": "EnvTree",
          "when": "workspaceContains:**/.git",
          "icon": "$(lock)",
          "contextualTitle": "EnvTree Secrets"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "envtree.init",
          "when": "view == envtreeExplorer",
          "group": "navigation@1"
        },
        {
          "command": "envtree.refresh",
          "when": "view == envtreeExplorer",
          "group": "navigation@2"
        },
        {
          "command": "envtree.settings",
          "when": "view == envtreeExplorer",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "envtree.addSecret",
          "when": "view == envtreeExplorer && viewItem == project",
          "group": "inline@1"
        },
        {
          "command": "envtree.inject",
          "when": "view == envtreeExplorer && viewItem == secret",
          "group": "inline@1"
        },
        {
          "command": "envtree.rotate",
          "when": "view == envtreeExplorer && viewItem == secret",
          "group": "inline@2"
        },
        {
          "command": "envtree.deleteSecret",
          "when": "view == envtreeExplorer && viewItem == secret",
          "group": "inline@3"
        }
      ],
      "commandPalette": [
        {
          "command": "envtree.init",
          "when": "workspaceContains:**/.git"
        },
        {
          "command": "envtree.addSecret",
          "when": "workspaceContains:**/.git"
        },
        {
          "command": "envtree.inject",
          "when": "workspaceContains:**/.git"
        },
        {
          "command": "envtree.rotate",
          "when": "workspaceContains:**/.git"
        },
        {
          "command": "envtree.deleteSecret",
          "when": "workspaceContains:**/.git"
        },
        {
          "command": "envtree.refresh",
          "when": "workspaceContains:**/.git"
        },
        {
          "command": "envtree.settings",
          "when": "workspaceContains:**/.git"
        }
      ]
    },
    "configuration": {
      "title": "EnvTree",
      "properties": {
        "envtree.daemonPort": {
          "type": "number",
          "default": 4848,
          "description": "Poort voor de EnvTree daemon",
          "minimum": 1024,
          "maximum": 65535
        },
        "envtree.daemonHost": {
          "type": "string",
          "default": "localhost",
          "description": "Host voor de EnvTree daemon"
        },
        "envtree.autoRefresh": {
          "type": "boolean",
          "default": true,
          "description": "Automatisch de EnvTree tree verversen"
        },
        "envtree.showSecretValues": {
          "type": "boolean",
          "default": false,
          "description": "Toon secret waarden in de tree (niet aanbevolen)"
        },
        "envtree.notificationTimeout": {
          "type": "number",
          "default": 5000,
          "description": "Timeout voor API calls in milliseconden",
          "minimum": 1000,
          "maximum": 30000
        }
      }
    },
    "keybindings": [
      {
        "command": "envtree.refresh",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r",
        "when": "view == envtreeExplorer"
      },
      {
        "command": "envtree.addSecret",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a", 
        "when": "view == envtreeExplorer"
      },
      {
        "command": "envtree.inject",
        "key": "ctrl+shift+i",
        "mac": "cmd+shift+i",
        "when": "workspaceContains:**/.git"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  }
}
