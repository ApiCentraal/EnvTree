# VSCode extension ignore file

# Source files
src/
test-workspace.js
vsc-extension-quickstart.md
*.ts
*.map

# Dependencies
node_modules/
**/node_modules/

# Parent directories (keep only needed files)
../
../daemon/
../cli/
../packages/
../infra/
../scripts/
../planning/
../.git/
../node_modules/

# Config files
tsconfig.json
.eslintrc*
.prettierrc*

# Documentation
*.md
!README.md

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db

# IDE files
.vscode/
.idea/

# Git
.git*
.gitignore

# EnvTree specific
master.key
vault.db.json
*.key
